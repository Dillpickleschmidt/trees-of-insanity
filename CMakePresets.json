{
  "version": 6,
  "configurePresets": [
    {
      "name": "core",
      "displayName": "Native core",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TOI_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "release-core",
      "displayName": "Native core release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release-core",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TOI_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "desktop",
      "displayName": "Desktop (native viewport)",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/desktop",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TOI_BUILD_TESTS": "ON",
        "TOI_ENABLE_VIEWPORT": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "core",
      "configurePreset": "core"
    },
    {
      "name": "release-core",
      "configurePreset": "release-core"
    },
    {
      "name": "desktop",
      "configurePreset": "desktop"
    }
  ],
  "testPresets": [
    {
      "name": "core",
      "configurePreset": "core",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
