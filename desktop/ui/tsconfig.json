{
	"compilerOptions": {
		"target": "ES2022",
		"useDefineForClassFields": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"strict": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"noEmit": true,
		"skipLibCheck": true,
		"types": ["bun-types"],
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": ["src", "vite.config.ts"]
}
