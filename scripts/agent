#!/usr/bin/env bash
# Agent-control seam: screenshots and screenshot-coordinate mouse/keyboard
# input for the running desktop shell (see CONTEXT.md "Agent-control mode").
# Input is injected at the Wayland compositor level, so the app receives it
# exactly like real user input; coordinates are pixels in the grim screenshot.
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
tool="$root/tools/agent/build/toi-input"

case "${1:-}" in
	screenshot)
		out="${2:-/tmp/toi-screenshot.png}"
		grim "$out"
		echo "$out"
		;;
	move | click | down | up | drag | scroll | key | type)
		if [ ! -x "$tool" ]; then
			make -C "$root/tools/agent" >/dev/null
		fi
		exec "$tool" "$@"
		;;
	*)
		cat >&2 <<'USAGE'
usage: agent <command>
  screenshot [out.png]           capture the screen (prints the path)
  move <x> <y>                   move the pointer
  click <x> <y> [left|right|middle]
  down <x> <y> [button] / up [button]
  drag <x1> <y1> <x2> <y2> [button]
  scroll <x> <y> <steps>         positive steps scroll down
  key <Name> [Name...]           Enter, Escape, Tab, arrows, ...
  type <text>                    type ASCII text via the active layout
Coordinates are screenshot pixels.
USAGE
		exit 2
		;;
esac
