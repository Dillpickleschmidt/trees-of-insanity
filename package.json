{
	"name": "trees-of-insanity",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run build:native && bun run build:ui && LD_PRELOAD=libstdc++.so.6 electrobun dev",
		"dev:watch": "concurrently \"bun run ui:watch\" \"LD_PRELOAD=libstdc++.so.6 TOI_USE_VITE_DEV_SERVER=1 electrobun dev --watch\"",
		"ui:watch": "vite --host 127.0.0.1 --port 5173",
		"build:ui": "vite build",
		"build:native": "cmake --preset ovrtx && cmake --build --preset ovrtx",
		"build": "bun run build:native && bun run build:ui && electrobun build --env=canary",
		"typecheck": "tsc --noEmit",
		"test:ffi": "bun test tests/nativeCore.test.ts",
		"verify:shell": "bun scripts/verify-shell.ts"
	},
	"dependencies": {
		"@kobalte/core": "^0.13.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"electrobun": "1.18.4-beta.6",
		"lucide-solid": "^1.23.0",
		"solid-js": "^1.9.5",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4",
		"@types/bun": "latest",
		"@types/three": "0.185.0",
		"concurrently": "^9.1.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-solid": "^2.11.0"
	}
}
