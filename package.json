{
	"name": "trees-of-insanity",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run build && build/desktop/trees_of_insanity",
		"ui:watch": "vite --config desktop/ui/vite.config.ts --host 127.0.0.1 --port 5173",
		"build:ui": "vite build --config desktop/ui/vite.config.ts",
		"build:desktop": "cmake --preset desktop && cmake --build --preset desktop",
		"build": "bun run build:ui && bun run build:desktop",
		"typecheck": "tsc -p desktop/ui/tsconfig.json --noEmit"
	},
	"dependencies": {
		"@kobalte/core": "^0.13.11",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-solid": "^1.23.0",
		"solid-js": "^1.9.5",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4",
		"@types/bun": "latest",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-solid": "^2.11.0"
	}
}
