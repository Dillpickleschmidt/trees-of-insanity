{
	"name": "trees-of-insanity",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun run build:ui && electrobun dev",
		"dev:watch": "concurrently \"bun run ui:watch\" \"TOI_USE_VITE_DEV_SERVER=1 electrobun dev --watch\"",
		"ui:watch": "vite --host 127.0.0.1 --port 5173",
		"build:ui": "vite build",
		"build": "bun run build:ui && electrobun build --env=canary",
		"typecheck": "tsc --noEmit",
		"verify:shell": "bun scripts/verify-shell.ts"
	},
	"dependencies": {
		"electrobun": "1.18.4-beta.6",
		"solid-js": "^1.9.5"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/three": "0.185.0",
		"autoprefixer": "^10.4.20",
		"concurrently": "^9.1.0",
		"postcss": "^8.4.49",
		"tailwindcss": "^3.4.16",
		"typescript": "^5.7.2",
		"vite": "^6.0.3",
		"vite-plugin-solid": "^2.11.0"
	}
}
